{
  "name": "video-player",
  "version": "1.1.0",
  "description": "Personal video player",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "jest",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1",
    "jest": "^30.3.0",
    "pngjs": "^7.0.0"
  },
  "build": {
    "appId": "com.local.videoplayer",
    "productName": "VideoPlayer",
    "icon": "assets/icon.png",
    "compression": "normal",
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "artifactName": "${productName}-${version}-${arch}-${target}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "extraResources": [
      { "from": "config.json", "to": "default-config.json" }
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
